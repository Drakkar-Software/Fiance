{
  "name": "fiance",
  "version": "1.1.1",
  "private": true,
  "description": "Application gratuite, privée et hors ligne pour organiser votre mariage : budget, liste d'invités, plan de table, prestataires, planning, checklist et mood board d'inspiration.",
  "keywords": [
    "mariage",
    "wedding",
    "wedding-planner",
    "organisation-mariage",
    "budget-mariage",
    "liste-invités",
    "plan-de-table",
    "prestataires-mariage",
    "planning-mariage",
    "checklist-mariage",
    "mood-board",
    "offline-first",
    "privacy-first",
    "expo",
    "react-native"
  ],
  "homepage": "https://fiance.pages.dev",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check": "expo install --check",
    "build:web": "expo export --platform web && node scripts/inject-pwa.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "server:dev": "cd server && wrangler dev",
    "deploy": "npm install && npx expo export --platform web && node scripts/inject-pwa.js && dotenv -- wrangler pages deploy dist --project-name fiance",
    "update:eas": "eas update --auto"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@drakkar.software/seahorse": "0.7.2",
    "@drakkar.software/starfish-client": "^2.3.0",
