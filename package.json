{
  "name": "wedding-os",
  "version": "1.0.0",
  "private": true,
  "description": "Application gratuite, privée et hors ligne pour organiser votre mariage : budget, liste d'invités, plan de table, prestataires, planning, checklist et mood board d'inspiration.",
  "keywords": [
    "mariage",
    "wedding",
    "wedding-planner",
    "organisation-mariage",
    "budget-mariage",
    "liste-invités",
    "plan-de-table",
    "prestataires-mariage",
    "planning-mariage",
    "checklist-mariage",
    "mood-board",
    "offline-first",
    "privacy-first",
    "expo",
    "react-native"
  ],
  "homepage": "https://wedding-os.pages.dev",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:push": "echo 'db:push skipped: expo-sqlite runs migrations at app startup'",
    "build:web": "expo export --platform web && node scripts/inject-pwa.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy": "npm install && npx expo export --platform web && node scripts/inject-pwa.js && dotenv -- wrangler pages deploy dist --project-name wedding-os"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@drakkar.software/starfish-client": "1.5.0",
    "@drakkar.software/starfish-protocol": "1.5.0",
    "@expo/log-box": "55.0.10",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^3.9.0",
    "@react-native-community/netinfo": "^11.0.0",
    "@shopify/react-native-skia": "2.4.18",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.30.0",
    "expo": "~55.0.11",
    "expo-build-properties": "^55.0.12",
    "expo-constants": "^55.0.11",
    "expo-crypto": "~55.0.12",
    "expo-document-picker": "~55.0.11",
    "expo-file-system": "^55.0.14",
    "expo-font": "^55.0.6",
    "expo-image-picker": "~55.0.16",
    "expo-linking": "^55.0.11",
    "expo-local-authentication": "~55.0.11",
    "expo-localization": "~55.0.11",
    "expo-notifications": "~55.0.16",
    "expo-print": "^55.0.12",
    "expo-router": "~55.0.10",
    "expo-secure-store": "~55.0.11",
    "expo-sharing": "^55.0.16",
    "expo-splash-screen": "^55.0.15",
    "expo-sqlite": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "^55.0.18",
    "i18next": "^24.0.0",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^4.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.54.0",
    "react-i18next": "^15.0.0",
    "react-native": "0.83.4",
    "react-native-css-interop": "^0.2.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "sonner": "2.0.5",
    "sonner-native": "0.21.0",
    "victory-native": "^41.0.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@shopify/react-native-skia"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@storybook/addon-mcp": "^0.5.0",
    "@storybook/react-vite": "^10.3.5",
    "@types/react": "~19.2.10",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.21.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "lucide-react": "^1.7.0",
    "prettier": "^3.4.0",
    "react-native-web-lite": "^1.112.4",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  }
}
