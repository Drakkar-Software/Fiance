{
  "expo": {
    "name": "Fiancé",
    "slug": "fiance",
    "version": "1.0.0",
    "description": "Application gratuite et privée pour organiser votre mariage : budget, liste d'invités, plan de table, prestataires, planning, checklist et mood board. Fonctionne hors ligne, données 100% privées.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fiance",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#EC4899",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fiance.app",
      "appStoreUrl": "https://apps.apple.com/app/fiance/id000000000",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Fiancé a besoin d'accéder à vos photos pour vos idées d'inspiration mariage.",
        "NSCameraUsageDescription": "Fiancé a besoin de l'appareil photo pour capturer vos inspirations mariage.",
        "NSFaceIDUsageDescription": "Utilisez Face ID pour déverrouiller Fiancé.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.fiance.app",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.fiance.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Fiancé — Organisez votre mariage",
      "shortName": "Fiancé",
      "description": "Application gratuite et privée pour organiser votre mariage : budget, invités, prestataires, planning et mood board.",
      "lang": "fr",
      "themeColor": "#EC4899",
      "backgroundColor": "#ffffff",
      "display": "standalone",
      "orientation": "portrait"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2da930dd-2220-4371-8588-05a9fe390c44"
    },
    "plugins": [
      "react-native-edge-to-edge",
      "expo-router",
      "expo-camera",
      "expo-sqlite",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-updates",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.0",
            "memorySize": 4096,
            "extraGradleProperties": {
              "org.gradle.jvmargs": "-Xmx4096m -XX:MaxMetaspaceSize=512m"
            }
          },
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ],
      "expo-localization",
      "expo-sharing",
      [
        "expo-iap",
        {
          "iosProductIds": [
            "com.fiance.app.premium.lifetime"
          ],
          "androidProductIds": [
            "com.fiance.app.premium.lifetime"
          ]
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2da930dd-2220-4371-8588-05a9fe390c44"
      }
    }
  }
}
