{
  "name": "fiance",
  "version": "2.0.1",
  "private": true,
  "description": "Application gratuite, privée et hors ligne pour organiser votre mariage : budget, liste d'invités, plan de table, prestataires, planning, checklist et mood board d'inspiration.",
  "keywords": [
    "mariage",
    "wedding",
    "wedding-planner",
    "organisation-mariage",
    "budget-mariage",
    "liste-invités",
    "plan-de-table",
    "prestataires-mariage",
    "planning-mariage",
    "checklist-mariage",
    "mood-board",
    "offline-first",
    "privacy-first",
    "expo",
    "react-native"
  ],
  "homepage": "https://fiance.drakkar.software",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check": "expo install --check",
    "build:web": "expo export --platform web && node scripts/generate-sitemap.mjs && node scripts/inject-pwa.js",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy": "npm install && npx expo export --platform web && node scripts/inject-pwa.js && dotenv -- wrangler pages deploy dist --project-name fiance",
    "typecheck": "tsc --noEmit",
    "update:eas": "eas update --auto",
    "submit:ios:xcode": "bash scripts/upload-ipa.sh"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
