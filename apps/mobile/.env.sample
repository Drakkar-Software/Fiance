# RevenueCat — public SDK keys
#
# These are PUBLIC keys, safe to embed in client code (they only grant read/purchase
# access scoped to your RevenueCat project, not account-level access). Never put a
# RevenueCat SECRET key (used server-side, e.g. for webhooks) in this file.
#
# Where to find them: RevenueCat dashboard → Project Settings → API keys, one key
# per "app" registered in the project (iOS app store app, Android play store app,
# and Web Billing app). Prefixes tell you which is which: appl_ = iOS, goog_ = Android,
# rcb_ = Web Billing, test_ = RevenueCat Test Store (synthetic, no real store call).
#
# Read via process.env.EXPO_PUBLIC_* (Metro inlines EXPO_PUBLIC_ vars into the bundle
# at build time — see apps/mobile/lib/revenuecat.ts / revenuecat.web.ts).

# iOS App Store public key (react-native-purchases, native only)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Android Play Store public key (react-native-purchases, native only)
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web Billing public key (@revenuecat/purchases-js, web only). Requires a Stripe
# account connected inside the RevenueCat dashboard (Project → Integrations → Stripe)
# before web checkout will work.
EXPO_PUBLIC_REVENUECAT_WEB_KEY=rcb_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# RevenueCat Test Store key (native only). Used automatically in dev builds
# (__DEV__ === true) instead of the iOS/Android keys above, so you can test
# purchases without a sandbox Apple ID / Play tester account. Never reaches
# production builds — dead-code-eliminated when __DEV__ is false.
EXPO_PUBLIC_REVENUECAT_TEST_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxx
