{
  "expo": {
    "name": "WeddingOS",
    "slug": "wedding-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "weddingos",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.weddingos.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "WeddingOS needs access to your photos for inspiration ideas.",
        "NSCameraUsageDescription": "WeddingOS needs camera access to take inspiration photos.",
        "NSFaceIDUsageDescription": "Use Face ID to unlock WeddingOS."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.weddingos.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "name": "WeddingOS",
      "shortName": "WOS",
      "themeColor": "#EC4899",
      "backgroundColor": "#ffffff",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-local-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "78314429-ee37-428e-85a6-1fa93f3286a7"
      }
    }
  }
}
