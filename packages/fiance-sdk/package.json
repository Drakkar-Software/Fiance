{
  "name": "@fiance/sdk",
  "version": "0.3.0",
  "description": "Headless business logic for the Fiancé wedding planner app.",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "source": "./src/index.ts",
  "react-native": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "require": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@drakkar.software/starfish-spaces": "3.0.0-alpha.61",
    "@drakkar.software/starfish-protocol": "3.0.0-alpha.50",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/bip39": "^2.0.0",
    "date-fns": "^3.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@drakkar.software/starfish-client": "3.0.0-alpha.51",
    "@drakkar.software/starfish-identities": "3.0.0-alpha.50",
    "@drakkar.software/starfish-keyring": "3.0.0-alpha.59",
    "@drakkar.software/starfish-sharing": "3.0.0-alpha.50",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  }
}
